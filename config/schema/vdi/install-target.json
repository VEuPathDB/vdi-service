{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veupathdb.github.io/vdi-service/schema/vdi/install-target.json",
  "type": "object",
  "allOf": [
    {
      "properties": {
        "controlSchema": {
          "type": "string"
        },
        "dataSchema": {
          "type": "string"
        },
        "dataTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "additionalItems": false
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "pass": {
          "type": "string"
        },
        "platform": {
          "enum": [
            "oracle",
            "postgres"
          ],
          "default": null
        },
        "poolSize": {
          "type": "integer",
          "minimum": 1,
          "maximum": 255,
          "default": 5
        },
        "targetName": {
          "$ref": "/vdi-service/schema/common.json#/definitions/installTarget"
        }
      },
      "required": [
        "controlSchema",
        "dataSchema",
        "pass",
        "targetName"
      ]
    },
    {
      "oneOf": [
        {
          "properties": {
            "ldapCn": {
              "type": "string"
            }
          },
          "required": [
            "ldapCn"
          ]
        },
        {
          "properties": {
            "dbName": {
              "type": "string"
            },
            "host": {
              "type": "string"
            },
            "port": {
              "$ref": "/vdi-service/schema/common.json#/definitions/port"
            }
          },
          "required": [
            "dbName",
            "host",
            "platform"
          ]
        }
      ]
    }
  ],
  "additionalProperties": false
}
