{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veupathdb.github.io/vdi-service/schema/vdi/config.json",
  "title": "VDI Configuration Schema",
  "type": "object",
  "properties": {
    "cacheDb": {
      "$ref": "#/$defs/cacheDb"
    },
    "daemons": {
      "type": "object",
      "properties": {
        "eventRouter": {
          "$ref": "/vdi-service/schema/vdi/daemons/event-router.json"
        },
        "pruner": {
          "$ref": "/vdi-service/schema/vdi/daemons/pruner.json"
        },
        "reconciler": {
          "$ref": "/vdi-service/schema/vdi/daemons/reconciler.json"
        }
      },
      "additionalProperties": false
    },
    "kafka": {
      "$ref": "/vdi-service/schema/vdi/kafka.json"
    },
    "lanes": {
      "type": "object",
      "properties": {
        "hardDelete": {
          "$ref": "/vdi-service/schema/vdi/lanes/hard-delete.json"
        },
        "import": {
          "$ref": "/vdi-service/schema/vdi/lanes/import.json"
        },
        "install": {
          "$ref": "/vdi-service/schema/vdi/lanes/install.json"
        },
        "reconciliation": {
          "$ref": "/vdi-service/schema/vdi/lanes/reconciliation.json"
        },
        "sharing": {
          "$ref": "/vdi-service/schema/vdi/lanes/sharing.json"
        },
        "softDelete": {
          "$ref": "/vdi-service/schema/vdi/lanes/soft-delete.json"
        },
        "updateMeta": {
          "$ref": "/vdi-service/schema/vdi/lanes/update-meta.json"
        }
      }
    },
    "ldap": {
      "$ref": "/vdi-service/schema/common.json#/$defs/ldap"
    },
    "objectStore": {
      "$ref": "/vdi-service/schema/vdi/object-store.json"
    },
    "plugins": {
      "type": "object",
      "additionalProperties": {
        "$ref": "/vdi-service/schema/vdi/plugin.json"
      }
    },
    "rabbit": {
      "type": "object",
      "properties": {
        "global": {
          "$ref": "/vdi-service/schema/vdi/rabbitmq.json"
        }
      },
      "required": [
        "global"
      ],
      "additionalProperties": false
    },
    "siteBuild": {
      "type": "string",
      "examples": [
        "build-65"
      ]
    },
    "targetDbs": {
      "type": "array",
      "items": {
        "$ref": "/vdi-service/schema/vdi/install-target.json"
      },
      "minItems": 1,
      "unevaluatedItems": false,
      "uniqueItems": true
    }
  },
  "required": [
    "cacheDb",
    "kafka",
    "ldap",
    "objectStore",
    "plugins",
    "rabbit",
    "siteBuild",
    "targetDbs"
  ],
  "additionalProperties": false,
  "$defs": {
    "cacheDb": {
      "type": "object",
      "properties": {
        "host": {
          "oneOf": [
            {
              "$ref": "/vdi-service/schema/common.json#/$defs/hostString"
            },
            {
              "$ref": "/vdi-service/schema/common.json#/$defs/interpolatedValue"
            },
            {
              "$ref": "/vdi-service/schema/common.json#/$defs/hostObject"
            }
          ]
        },
        "user": {
          "type": "string"
        },
        "pass": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "default": "vdi"
        },
        "poolSize": {
          "type": "integer",
          "minimum": 1,
          "default": 255
        }
      },
      "required": [
        "host",
        "user",
        "pass"
      ]
    }
  }
}
