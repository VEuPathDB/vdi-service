{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veupathdb.github.io/vdi-service/schema/vdi/config.json",
  "title": "VDI Configuration Schema",
  "type": "object",
  "properties": {
    "cacheDb": {
      "$ref": "#/definitions/cacheDb"
    },
    "daemons": {
      "type": "object",
      "properties": {
        "eventRouter": {
          "$ref": "/vdi-service/schema/vdi/daemons/event-router.json#"
        },
        "pruner": {
          "$ref": "/vdi-service/schema/vdi/daemons/pruner.json#"
        },
        "reconciler": {
          "$ref": "/vdi-service/schema/vdi/daemons/reconciler.json#"
        }
      },
      "additionalProperties": false
    },
    "kafka": {
      "$ref": "kafka.json#"
    },
    "lanes": {
      "type": "object",
      "properties": {
        "hardDelete": {
          "$ref": "/vdi-service/schema/vdi/lanes/hard-delete.json#"
        },
        "import": {
          "$ref": "/vdi-service/schema/vdi/lanes/import.json#"
        },
        "install": {
          "$ref": "/vdi-service/schema/vdi/lanes/install.json#"
        },
        "reconciliation": {
          "$ref": "/vdi-service/schema/vdi/lanes/reconciliation.json#"
        },
        "sharing": {
          "$ref": "/vdi-service/schema/vdi/lanes/sharing.json#"
        },
        "softDelete": {
          "$ref": "/vdi-service/schema/vdi/lanes/soft-delete.json#"
        },
        "updateMeta": {
          "$ref": "/vdi-service/schema/vdi/lanes/update-meta.json#"
        }
      }
    },
    "ldap": {
      "$ref": "/vdi-service/schema/common.json#/definitions/ldap"
    },
    "objectStore": {
      "$ref": "object-store.json#"
    },
    "plugins": {
      "type": "object",
      "additionalProperties": {
        "$ref": "plugin.json#"
      }
    },
    "rabbit": {
      "type": "object",
      "properties": {
        "global": {
          "$ref": "rabbitmq.json#"
        }
      },
      "required": [
        "global"
      ],
      "additionalProperties": false
    },
    "siteBuild": {
      "type": "string",
      "examples": [
        "build-65"
      ]
    },
    "targetDbs": {
      "type": "object",
      "additionalProperties": {
        "$ref": "install-target.json#"
      },
      "minProperties": 1
    }
  },
  "required": [
    "cacheDb",
    "kafka",
    "ldap",
    "objectStore",
    "plugins",
    "rabbit",
    "siteBuild",
    "targetDbs"
  ],
  "additionalProperties": false,
  "definitions": {
    "cacheDb": {
      "type": "object",
      "properties": {
        "host": {
          "oneOf": [
            {
              "$ref": "/vdi-service/schema/common.json#/definitions/hostString"
            },
            {
              "$ref": "/vdi-service/schema/common.json#/definitions/interpolatedValue"
            },
            {
              "$ref": "/vdi-service/schema/common.json#/definitions/hostObject"
            }
          ]
        },
        "user": {
          "type": "string"
        },
        "pass": {
          "type": "string"
        },
        "poolSize": {
          "type": "integer",
          "minimum": 1,
          "default": 255
        }
      },
      "required": [
        "host",
        "user",
        "pass"
      ]
    }
  }
}
