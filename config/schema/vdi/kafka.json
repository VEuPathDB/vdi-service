{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veupathdb.github.io/vdi-service/schema/vdi/kafka.json",
  "title": "Kafka Configuration",
  "type": "object",
  "properties": {
    "servers": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "/vdi-service/schema/common.json#/$defs/hostString"
          },
          {
            "$ref": "/vdi-service/schema/common.json#/$defs/interpolatedValue"
          },
          {
            "$ref": "/vdi-service/schema/common.json#/$defs/hostObject"
          }
        ]
      },
      "unevaluatedItems": false
    },
    "listeners": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uri"
      },
      "unevaluatedItems": false
    },
    "consumers": {
      "$ref": "#/$defs/consumers"
    },
    "producers": {
      "$ref": "#/$defs/producers"
    }
  },
  "required": [
    "listeners",
    "servers",
    "consumers"
  ],
  "additionalProperties": false,
  "$defs": {
    "consumers": {
      "type": "object",
      "properties": {
        "autoCommitInterval": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "5s"
        },
        "autoOffsetReset": {
          "enum": [
            "earliest",
            "latest",
            "none"
          ],
          "default": "earliest"
        },
        "connectionsMaxIdle": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "9m"
        },
        "groupId": {
          "type": "string"
        },
        "groupInstanceId": {
          "type": "string",
          "default": null
        },
        "defaultApiTimeout": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "1m"
        },
        "enableAutoCommit": {
          "type": "boolean",
          "default": true
        },
        "fetchMaxBytes": {
          "type": "integer",
          "minimum": 0,
          "default": 52428800
        },
        "fetchMinBytes": {
          "type": "integer",
          "minimum": 0,
          "default": 1
        },
        "heartbeatInterval": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "3s"
        },
        "maxPollInterval": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "5m"
        },
        "maxPollRecords": {
          "type": "integer",
          "minimum": 0,
          "default": 500
        },
        "pollDuration": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "2s"
        },
        "receiveBufferSize": {
          "type": "integer",
          "minimum": -1,
          "default": 65536
        },
        "reconnectBackoffMaxTime": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "1s"
        },
        "reconnectBackoffTime": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "50ms"
        },
        "requestTimeout": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "30s"
        },
        "retryBackoffTime": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "100ms"
        },
        "sendBufferSize": {
          "type": "integer",
          "minimum": -1,
          "default": 131072
        },
        "sessionTimeout": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "45s"
        }
      },
      "required": [
        "consumerGroupId"
      ],
      "additionalProperties": false
    },
    "producers": {
      "type": "object",
      "properties": {
        "bufferMemoryBytes": {
          "type": "integer",
          "minimum": 0,
          "default": 33554432
        },
        "compressionType": {
          "enum": [
            "none",
            "gzip",
            "snappy",
            "lz4",
            "zstd"
          ],
          "default": "none"
        },
        "sendRetries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2147483647,
          "default": 2147483647
        },
        "batchSize": {
          "type": "integer",
          "minimum": 0,
          "default": 16384
        },
        "connectionsMaxIdle": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "9m"
        },
        "deliveryTimeout": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "2m"
        },
        "lingerTime": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "5ms"
        },
        "maxBlockingTimeout": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "1m"
        },
        "maxRequestSize": {
          "type": "integer",
          "minimum": 0,
          "default": 1048576
        },
        "receiveBufferSize": {
          "type": "integer",
          "minimum": -1
        },
        "requestTimeout": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "30s"
        },
        "sendBufferSize": {
          "type": "integer",
          "minimum": -1,
          "default": 131072
        },
        "reconnectBackoffMaxTime": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "1s"
        },
        "reconnectBackoffTime": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "50ms"
        },
        "retryBackoffTime": {
          "$ref": "/vdi-service/schema/common.json#/$defs/duration",
          "default": "100ms"
        }
      },
      "additionalProperties": false
    }
  }
}
