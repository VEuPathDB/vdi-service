{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veupathdb.github.io/vdi-service/schema/vdi/lanes/update-meta.json",
  "title": "Dataset Metadata Upsert Lane Config",
  "type": "object",
  "allOf": [
    {
      "$ref": "/vdi-service/schema/vdi/lanes/lane-common.json#"
    },
    {
      "properties": {
        "kafkaConsumerId": {
          "default": "update-meta-lane-receive"
        },
        "kafkaProducerId": {
          "$ref": "/vdi-service/schema/vdi/lanes/lane-common.json#/$defs/kafkaProducerId",
          "default": "update-meta-lane-send"
        },
        "memoryQueueSize": {
          "default": 5
        },
        "workerCount": {
          "default": 5
        },
        "eventChannel": {
          "default": "update-meta-triggers"
        },
        "eventKey": {
          "default": "update-meta-trigger"
        }
      }
    }
  ],
  "additionalProperties": false
}
