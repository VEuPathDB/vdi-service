{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veupathdb.github.io/vdi-service/schema/container-core/config.json",
  "title": "Container Core Library Config",
  "type": "object",
  "properties": {
    "ldap": {
      "$ref": "/vdi-service/schema/common.json#/$defs/ldap"
    },
    "authentication": {
      "type": "object",
      "properties": {
        "adminToken": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 32
            },
            {
              "$ref": "/vdi-service/schema/common.json#/$defs/interpolatedValue"
            }
          ]
        },
        "oauth": {
          "$ref": "#/$defs/oauth"
        }
      }
    },
    "http": {
      "$ref": "#/$defs/http"
    },
    "databases": {
      "type": "object",
      "properties": {
        "accountDb": {
          "$ref": "/vdi-service/schema/container-core/database.json#"
        },
        "appDb": {
          "$ref": "/vdi-service/schema/container-core/database.json#"
        },
        "userDb": {
          "$ref": "/vdi-service/schema/container-core/database.json#"
        }
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "http": {
      "title": "HTTP Server Config",
      "type": "object",
      "properties": {
        "enableCors": {
          "title": "Enable Cross-Origin Resource Sharing",
          "type": "boolean",
          "default": false
        },
        "bindPort": {
          "title": "HTTP Server Port Binding",
          "$ref": "/vdi-service/schema/common.json#/$defs/port",
          "default": 80
        }
      }
    },
    "oauth": {
      "title": "OAuth Connection Config",
      "type": "object",
      "properties": {
        "clientId": {
          "type": "string"
        },
        "clientSecret": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "keyStoreFile": {
          "oneOf": [
            {
              "type": "string",
              "format": "uri-reference"
            },
            {
              "$ref": "/vdi-service/schema/common.json#/$defs/interpolatedValue"
            }
          ]
        },
        "keyStorePass": {
          "type": "string"
        }
      }
    }
  }
}
