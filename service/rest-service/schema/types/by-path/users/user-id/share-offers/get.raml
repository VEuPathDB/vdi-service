#%RAML 1.0 Library

uses:
  common: ../../../../common.raml

types:
  ShareOfferEntry:
    displayName: Share Offer
    additionalProperties: false
    properties:
      datasetId: common.VdiId
      owner: common.DatasetOwner
      shareStatus: ShareOfferStatus
      datasetType: common.DatasetTypeInfo
      projectIds: common.ProjectId[]

  ShareOfferStatus:
    displayName: Share Offer Status
    type: string
    enum:
    - open
    - accepted
    - rejected
