{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://veupathdb.github.io/vdi-service/schema/vdi/install-target.json",
  "type": "object",
  "allOf": [
    {
      "properties": {
        "controlSchema": {
          "type": "string"
        },
        "dataSchema": {
          "type": "string"
        },
        "dataTypes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "unevaluatedItems": false,
          "uniqueItems": true
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "pass": {
          "type": "string"
        },
        "platform": {
          "enum": [
            "oracle",
            "postgres"
          ],
          "default": null
        },
        "poolSize": {
          "type": "integer",
          "minimum": 1,
          "maximum": 255,
          "default": 5
        },
        "targetName": {
          "$ref": "/vdi-service/schema/common.json#/$defs/installTarget"
        },
        "propertySchema": {
          "oneOf": [
            {
              "title": "Inline Schema Definition",
              "$ref": "https://json-schema.org/draft/2020-12/schema"
            },
            {
              "title": "Remote Schema File",
              "type": "string",
              "pattern": "^(https?)?://([0-9a-zA-Z][\\w-]+(?:\\.[0-9a-zA-Z][\\w-]*)*)((?:/[\\w%.~-]+)+)(\\?.+)?$"
            },
            {
              "title": "Local Schema File",
              "description": "Path to a local schema file.  If the path is absolute, and does not exist in the host filesystem, the service jar contents will be checked as well.",
              "type": "string",
              "format": "uri-reference"
            }
          ]
        }
      },
      "required": [
        "controlSchema",
        "dataSchema",
        "pass",
        "targetName",
        "propertySchema"
      ]
    },
    {
      "oneOf": [
        {
          "properties": {
            "ldapCn": {
              "type": "string"
            }
          },
          "required": [
            "ldapCn"
          ]
        },
        {
          "properties": {
            "dbName": {
              "type": "string"
            },
            "host": {
              "oneOf": [
                {
                  "$ref": "/vdi-service/schema/common.json#/$defs/hostString"
                },
                {
                  "$ref": "/vdi-service/schema/common.json#/$defs/interpolatedValue"
                },
                {
                  "$ref": "/vdi-service/schema/common.json#/$defs/hostObject"
                }
              ]
            }
          },
          "required": [
            "dbName",
            "host",
            "platform"
          ]
        },
        {
          "properties": {
            "dbName": {
              "type": "string"
            },
            "host": {
              "type": "string",
              "pattern": "^[\\w-.]+$"
            },
            "port": {
              "$ref": "/vdi-service/schema/common.json#/$defs/port"
            }
          },
          "required": [
            "dbName",
            "host",
            "platform"
          ]
        }
      ]
    }
  ],
  "unevaluatedProperties": false
}
